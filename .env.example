# Resend (https://resend.com) - used by the /bonus book-reader signup
# API key with "sending" + "contacts" access. Get it at resend.com/api-keys
RESEND_API_KEY=

# Verified sender, e.g. "Software Cafrers <newsletter@softwarecafrers.com>"
# The domain must be verified in Resend before emails will deliver.
RESEND_EMAIL_FROM=

# Segment readers land in when they sign up from the book QR. Use a dedicated
# segment (e.g. "Lectores del libro") if you want to know who came from the book.
RESEND_SEGMENT_ID=

# Secret that unlocks the /bonus content. Anything unguessable works,
# e.g. `openssl rand -hex 16`. It is sent in the welcome email link and the
# post-signup redirect, so readers can't reach the bonus without signing up.
BONUS_TOKEN=

# Optional: public base URL, defaults to https://www.softwarecafrers.com
# Used to build the bonus link (NEXT_PUBLIC_URL + /bonus) in the welcome email.
# NEXT_PUBLIC_URL=
